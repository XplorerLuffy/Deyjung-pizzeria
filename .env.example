# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Secret — server-side only, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Loyverse POS ───────────────────────────────────────────────
# Create a token at: Loyverse Back Office → Integrations → Access Tokens
LOYVERSE_API_TOKEN=

# Found in Loyverse Back Office → Settings → Store info
LOYVERSE_STORE_ID=

# Found in Loyverse Back Office → Employees (any employee's ID works)
LOYVERSE_EMPLOYEE_ID=

# ── Site ───────────────────────────────────────────────────────
# Full URL of your deployed site (no trailing slash)
# Used by the QR code generator to build correct table URLs
NEXT_PUBLIC_SITE_URL=https://your-domain.com
